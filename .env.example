# Imposter Environment Configuration Example
# Copy this file to .env and fill in your secrets.

# --- AI Provider Configuration ---
# API Key for OpenRouter (optional if using local Ollama)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# API Key for AssemblyAI (required for system audio transcription)
ASSEMBLY_AI_SERVICE_KEY=your_assemblyai_api_key_here

# --- System Configuration ---
# Use the default port for local Ollama instance
OLLAMA_PORT=11434

# --- Developer Mode (optional) ---
# Set to 'true' to enable debugging tools
DEBUG_MODE=false
