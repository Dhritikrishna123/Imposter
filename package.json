{
  "name": "imposter",
  "version": "1.0.0",
  "description": "Imposter: Beating a Broken System",
  "author": "Puskar Roy",
  "repository": {
    "type": "git",
    "url": "https://github.com/Puskar-Roy/Imposter.git"
  },
  "main": "src/main/index.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:fast": "electron-builder",
    "build:linux": "electron-builder --linux",
    "build:mac": "electron-builder --mac",
    "build:all": "electron-builder -wml",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix",
    "format": "prettier --write \"src/**/*.{js,css,html}\" \"*.md\""
  },
  "dependencies": {
    "dotenv": "^17.4.0",
    "highlight.js": "^11.9.0",
    "marked": "^12.0.0",
    "tesseract.js": "^7.0.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "fs-extra": "^11.3.4",
    "javascript-obfuscator": "^5.4.1",
    "prettier": "^3.2.5"
  },
  "build": {
    "appId": "com.imposter.app",
    "productName": "Imposter",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "public/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.png"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.png",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "build/icon.png",
      "category": "Productivity"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  }
}
