{
  "name": "imposter",
  "version": "1.0.0",
  "description": "Imposter: Beating a Broken System",
  "author": "Puskar Roy",
  "repository": {
    "type": "git",
    "url": "https://github.com/Puskar-Roy/Imposter.git"
  },
  "main": "src/main/index.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "dependencies": {
    "highlight.js": "^11.9.0",
    "marked": "^12.0.0",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.imposter.app",
    "productName": "Imposter",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "public/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "public/logo.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  }
}
